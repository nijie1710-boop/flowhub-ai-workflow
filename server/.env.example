PORT=3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL. Use either DATABASE_URL or the DB_* fields below.
# DATABASE_URL=postgres://flowhub_app:change_me@127.0.0.1:5432/flowhub
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=flowhub
DB_USER=flowhub_app
DB_PASSWORD=change_me
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000

# SMTP provider for email verification codes.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=change_me@example.com
SMTP_PASS=change_me
SMTP_FROM="FlowHub" <change_me@example.com>
