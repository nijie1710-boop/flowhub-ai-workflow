{
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "cd server && npm ci",
  "buildCommand": "rm -rf public && mkdir -p public && cp index.html public/index.html && if [ -d assets ]; then cp -R assets public/assets; fi && if [ -d src ]; then cp -R src public/src; fi",
  "outputDirectory": "public",
  "functions": {
    "api/[...path].js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]?path=$1"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
